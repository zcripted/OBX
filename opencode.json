{
  "$schema": "https://opencode.ai/config.json",
  "compaction": { "auto": true, "prune": true, "reserved": 4096 },
  "provider": {
    "ollama": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Ollama (local)",
      "options": { "baseURL": "http://localhost:11434/v1" },
      "models": {
        "qwen3-coder-agent": {
          "name": "Qwen3 Coder (agent)",
          "tool_call": true,
          "options": { "temperature": 0.1 }
        }
      }
    }
  }
}